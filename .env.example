# ── Host auth (optional) ─────────────────────────────────────
# When set, the host control panel requires this key. Unset / empty
# disables auth (anyone with /host access can control the game).
LOGIN_KEY=

# ── Single-room event mode (optional) ────────────────────────
# When EVENT_QUIZ_PATH is set, the server pre-creates a single room
# at boot and /play + /lobby auto-resolve the PIN via /api/active-room.
# EVENT_QUIZ_PATH=public/quizzes/sample.json
# EVENT_PIN=RCV2026
# EVENT_MIN_WINNERS=1

# ── Host / port overrides ────────────────────────────────────
# PORT=3000
# HOST=0.0.0.0
